rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() { return request.auth != null; }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isValidId(id) { 
      return id is string && id.size() > 0 && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); 
    }

    function isValidStudent(data) {
      return data.keys().hasAll(['name', 'studentId', 'faceDescriptor', 'teacherUid', 'createdAt']) &&
             data.keys().size() == 5 &&
             data.name is string && data.name.size() > 0 && data.name.size() <= 100 &&
             data.studentId is string && data.studentId.size() > 0 && data.studentId.size() <= 50 &&
             data.faceDescriptor is list && data.faceDescriptor.size() == 128 && data.faceDescriptor[0] is number &&
             data.teacherUid == request.auth.uid &&
             data.createdAt is number;
    }

    match /students/{docId} {
      allow read: if isSignedIn() && existing().teacherUid == request.auth.uid;
      allow create: if isSignedIn() && isValidId(docId) && isValidStudent(incoming());
      allow update: if isSignedIn() && isValidId(docId) && 
                    existing().teacherUid == request.auth.uid &&
                    incoming().teacherUid == existing().teacherUid &&
                    incoming().createdAt == existing().createdAt &&
                    incoming().diff(existing()).affectedKeys().hasOnly(['name', 'studentId', 'faceDescriptor']) &&
                    incoming().name is string && incoming().name.size() > 0 && incoming().name.size() <= 100 &&
                    incoming().studentId is string && incoming().studentId.size() > 0 && incoming().studentId.size() <= 50 &&
                    incoming().faceDescriptor is list && incoming().faceDescriptor.size() == 128 && incoming().faceDescriptor[0] is number;
      allow delete: if isSignedIn() && existing().teacherUid == request.auth.uid;
      allow list: if isSignedIn() && resource.data.teacherUid == request.auth.uid;
    }

    function isValidAttendanceRecord(data) {
      return data.keys().hasAll(['studentId', 'date', 'status', 'timestamp', 'teacherUid']) &&
             data.keys().size() == 5 &&
             data.studentId is string && data.studentId.size() > 0 && data.studentId.size() <= 128 &&
             data.date is string && data.date.size() == 10 && data.date.matches('^[0-9]{4}-[0-9]{2}-[0-9]{2}$') &&
             data.status in ['present', 'absent', 'late_present'] &&
             data.timestamp is number &&
             data.teacherUid == request.auth.uid;
    }

    match /settings/{docId} {
      allow read: if isSignedIn() && docId == request.auth.uid;
      allow write: if isSignedIn() && docId == request.auth.uid;
    }

    match /attendance_records/{recordId} {
      allow read: if isSignedIn() && existing().teacherUid == request.auth.uid;
      allow create: if isSignedIn() && isValidId(recordId) && isValidAttendanceRecord(incoming());
      allow update: if isSignedIn() && isValidId(recordId) && 
                    existing().teacherUid == request.auth.uid &&
                    incoming().teacherUid == existing().teacherUid &&
                    incoming().studentId == existing().studentId &&
                    incoming().date == existing().date &&
                    incoming().diff(existing()).affectedKeys().hasOnly(['status', 'timestamp']) &&
                    incoming().status in ['present', 'absent', 'late_present'] &&
                    incoming().timestamp is number;
      allow delete: if false; // Logs are append-only mostly, no delete
      allow list: if isSignedIn() && resource.data.teacherUid == request.auth.uid;
    }
  }
}
